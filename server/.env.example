# Server-side env vars — copy this file to server/.env and fill in your values

# Spotify Developer credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Must exactly match what's registered in your Spotify dashboard
# Spotify now requires 127.0.0.1 (not localhost) for OAuth redirect URIs
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Genius API client access token (https://genius.com/api-clients)
GENIUS_TOKEN=""

# Optional — defaults shown
# Frontend origin for CORS and post-OAuth redirect
FRONTEND_URL=http://localhost:5173
# Server port
PORT=3000
