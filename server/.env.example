# Server-side env vars — copy this file to server/.env and fill in your values

# Spotify Developer credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Must exactly match what's registered in your Spotify dashboard
# Spotify now requires 127.0.0.1 (not localhost) for OAuth redirect URIs
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Genius API client access token (https://genius.com/api-clients)
GENIUS_TOKEN=""

# YouTube Data API v3 key — used for demo mode song search (https://console.cloud.google.com)
# Free tier: 10,000 units/day. Each search costs 100 units (~100 searches/day free)
YOUTUBE_API_KEY=""

# Required in production — stable 64-char hex string (generate with: openssl rand -hex 32)
# Without this a random key is generated per restart, invalidating all sessions on redeploy
SESSION_SECRET=""

# Optional — defaults shown
# Frontend origin for CORS and post-OAuth redirect
FRONTEND_URL=http://localhost:5173
# Server port
PORT=3000
